# ─────────────────────────────────────────────
# Client (Vite) — safe to expose to browser
# ─────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ─────────────────────────────────────────────
# Supabase Edge Function secrets
# Set with: supabase secrets set KEY=value
# SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY are auto-injected.
# ─────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe price IDs — one per (plan × cycle × currency).
# Format: STRIPE_PRICE_<PLAN>_<CYCLE>_<CURRENCY>
# Only Basic and Professional need prices; Free and Enterprise do not.
STRIPE_PRICE_BASIC_MONTHLY_USD=price_...
STRIPE_PRICE_BASIC_ANNUAL_USD=price_...
STRIPE_PRICE_BASIC_MONTHLY_EUR=price_...
STRIPE_PRICE_BASIC_ANNUAL_EUR=price_...
STRIPE_PRICE_BASIC_MONTHLY_GBP=price_...
STRIPE_PRICE_BASIC_ANNUAL_GBP=price_...
STRIPE_PRICE_PROFESSIONAL_MONTHLY_USD=price_...
STRIPE_PRICE_PROFESSIONAL_ANNUAL_USD=price_...
STRIPE_PRICE_PROFESSIONAL_MONTHLY_EUR=price_...
STRIPE_PRICE_PROFESSIONAL_ANNUAL_EUR=price_...
STRIPE_PRICE_PROFESSIONAL_MONTHLY_GBP=price_...
STRIPE_PRICE_PROFESSIONAL_ANNUAL_GBP=price_...
